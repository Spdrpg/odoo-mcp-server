# ── Odoo connection ───────────────────────────────────────────────────────────
# Full URL of your Odoo instance (no trailing slash)
ODOO_URL=https://abz-innovation.odoo.com

# Database name — for Odoo Online this is the subdomain part of the URL
# e.g. for https://abz-innovation.odoo.com  →  abz-innovation
ODOO_DB=abz-innovation-kft-odoosh-main-21986310

# The login email of the Odoo user whose API key you are using
ODOO_USER=admin@example.com

# API key generated in Odoo (replaces the password in every API call)
# See README.md for how to generate this key
ODOO_API_KEY=your_odoo_api_key_here

# ── Server ─────────────────────────────────────────────────────────────────────
# Port to listen on (Railway sets this automatically)
PORT=8000
